# ── Required ───────────────────────────────────────────────────
# Google Gemini API key (used by /api/chat for AI routing)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional: SMS via Twilio ───────────────────────────────────
# When set, every new booking sends:
#   • a customer confirmation SMS ("we received your message…")
#   • an owner alert SMS to OWNER_PHONE
# Booking flow still works if these are missing — SMS is just skipped.
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15025551234
OWNER_PHONE=+15025551234

# ── Optional: Email notifications via Gmail SMTP ───────────────
# When set, every new booking emails the owner with the lead details.
# GMAIL_APP_PASSWORD must be a 16-char Google App Password (not your
# regular Gmail password). Generate one at:
#   https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the Google account.
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
OWNER_EMAIL=owner@example.com
# Optional override for the From: header on lead emails. Defaults to
# "Derby Strong Leads <GMAIL_USER>".
# LEAD_FROM_EMAIL=Derby Strong Leads <leads@derbystrong.com>

# ── Optional: Vercel KV (Upstash Redis REST) durable storage ───
# When set, /api/bookings, /api/config, /api/chat-config, and /api/analytics
# persist to Redis instead of the local filesystem (which is read-only on
# Vercel serverless). Attach a Vercel KV / Upstash integration to the
# project and these are injected automatically — no manual entry needed.
# Without them, the widget still renders but admin saves and lead history
# will not survive restarts on Vercel.
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token

# ── Optional: Vercel Blob for image uploads ────────────────────
# When set, /api/upload stores images in Vercel Blob instead of the
# local filesystem (which is read-only on Vercel serverless). Attach
# a Blob store to the project and this is injected automatically.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
