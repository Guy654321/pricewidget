# ── Required ───────────────────────────────────────────────────
# Google Gemini API key (used by /api/chat for AI routing)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional: SMS confirmations via Twilio ─────────────────────
# Booking flow works without these, but no SMS will be sent.
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15025551234
OWNER_PHONE=+15025551234

# ── Optional: Email notifications via Resend ───────────────────
# Used by /api/notify to email the owner when a lead is captured.
RESEND_API_KEY=your-resend-api-key
OWNER_EMAIL=owner@example.com
