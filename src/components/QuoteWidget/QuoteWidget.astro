      '</a>';
    }).join('');

    modal.querySelector('.ds-booking-modal-inner').innerHTML =
      '<div class="ds-booking-success">' +
        '<div class="ds-booking-success-icon">' +
          '<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>' +
        '</div>' +
        '<div class="ds-booking-success-title">You\'re all set!</div>' +
        '<div class="ds-booking-success-body">' +
