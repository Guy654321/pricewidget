  // ── Photo upload ─────────────────────────────────────────────────────────────
  attachBtn.addEventListener('click', function () {
    fileInput.click();
  });

  fileInput.addEventListener('change', function () {
    addFiles(fileInput.files);
    fileInput.value = '';
  });

  function addFiles(files) {
    Array.from(files).forEach(function (file) {
      if (!file.type.startsWith('image/')) return;
      if (pendingImages.length >= 3) return;
      var reader = new FileReader();
      reader.onload = function (e) {
        pendingImages.push({ dataUrl: e.target.result, mediaType: file.type });
        renderPendingImages();
      };
      reader.readAsDataURL(file);
    });
  }

  function renderPendingImages() {
    imgPendingRow.innerHTML = pendingImages.map(function (img, idx) {
      return (
        '<div class="ds-img-pending">' +
          '<img src="' + escAttr(img.dataUrl) + '" alt="Attached image ' + (idx + 1) + '">' +
          '<button class="ds-img-remove" data-idx="' + idx + '" type="button" aria-label="Remove image">' +
            '<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>' +
          '</button>' +
        '</div>'
      );
    }).join('');
    attachBtn.setAttribute('data-has-image', pendingImages.length > 0 ? 'true' : 'false');

    imgPendingRow.querySelectorAll('.ds-img-remove').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var idx = parseInt(btn.getAttribute('data-idx'), 10);
        pendingImages.splice(idx, 1);
        renderPendingImages();
      });
    });
  }

  // ── Drag and drop ────────────────────────────────────────────────────────────
  var chatScreen = panel.querySelector('.ds-screen[data-screen="chat"]');

  chatScreen.addEventListener('dragover', function (e) {
    e.preventDefault();
    dropZone.setAttribute('data-active', 'true');
  });
  chatScreen.addEventListener('dragleave', function (e) {
    if (!chatScreen.contains(e.relatedTarget)) {
      dropZone.setAttribute('data-active', 'false');
    }
  });
  chatScreen.addEventListener('drop', function (e) {
    e.preventDefault();
    dropZone.setAttribute('data-active', 'false');
    if (e.dataTransfer && e.dataTransfer.files) {
      addFiles(e.dataTransfer.files);
    }
  });

  // ── Chat ─────────────────────────────────────────────────────────────────────
  var GREETING = "Hey! I'm the Derby Strong assistant. What's going on with your garage door today?";

  function renderGreeting() {
    greetingShown = true;
    appendAssistantBubble(GREETING);

    // Quick-start suggestion pills
    var suggestions = ['My spring broke', "Door won't close", 'Opener is noisy', 'Door is off track'];
    var suggestRow = document.createElement('div');
    suggestRow.className = 'ds-chat-suggestions';
    suggestRow.innerHTML = suggestions.map(function (s) {
      return '<button class="ds-chat-suggest-pill" type="button">' + esc(s) + '</button>';
    }).join('');
    chatMessages.appendChild(suggestRow);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    suggestRow.querySelectorAll('.ds-chat-suggest-pill').forEach(function (btn) {
      btn.addEventListener('click', function () {
        suggestRow.remove();
        sendChatMessage(btn.textContent);
      });
    });
  }

  function appendUserBubble(text) {
    var bubble = document.createElement('div');
    bubble.className = 'ds-msg-bubble';
    bubble.setAttribute('data-role', 'user');
    bubble.textContent = text;
    chatMessages.appendChild(bubble);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return bubble;
  }

  function appendUserBubbleWithImages(text, images) {
    var bubble = document.createElement('div');
    bubble.className = 'ds-msg-bubble';
    bubble.setAttribute('data-role', 'user');
    var html = images.map(function (img) {
      return '<img class="ds-msg-img" src="' + escAttr(img.dataUrl) + '" alt="Uploaded photo">';
    }).join('');
    if (text) html += '<span>' + esc(text) + '</span>';
    bubble.innerHTML = html;
    chatMessages.appendChild(bubble);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return bubble;
  }

  function appendAssistantBubble(text) {
    var bubble = document.createElement('div');
    bubble.className = 'ds-msg-bubble';
    bubble.setAttribute('data-role', 'assistant');
    bubble.textContent = text;
    chatMessages.appendChild(bubble);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return bubble;
  }

  function setTyping(visible) {
    typingEl.setAttribute('data-visible', visible ? 'true' : 'false');
    typingEl.setAttribute('aria-hidden', visible ? 'false' : 'true');
  }

  function setChatDisabled(disabled) {
    chatInput.disabled = disabled;
    attachBtn.disabled = disabled;
    chatForm.querySelector('.ds-chat-send').disabled = disabled;
  }

  async function sendChatMessage(userText) {
    var hasPending = pendingImages.length > 0;
    var content;

    if (hasPending) {
      content = [];
      if (userText) content.push({ type: 'text', text: userText });
      pendingImages.forEach(function (img) {
        var base64 = img.dataUrl.split(',')[1];
        content.push({
          type: 'image',
          source: { type: 'base64', media_type: img.mediaType, data: base64 },
        });
      });
      messages.push({ role: 'user', content: content });
      appendUserBubbleWithImages(userText, pendingImages);
      trackEvent('chat_message_sent', {
        role: 'user',
        message: userText || '(image)',
        photoCount: pendingImages.length,
      });
      pendingImages = [];
      renderPendingImages();
    } else {
      messages.push({ role: 'user', content: userText });
      appendUserBubble(userText);
      trackEvent('chat_message_sent', { role: 'user', message: userText });
    }

    setChatDisabled(true);
    setTyping(true);

    streamController = new AbortController();
    var bubble      = appendAssistantBubble('');
    var accumulated = '';

    try {
      var response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: messages }),
        signal: streamController.signal,
      });

      if (!response.ok) throw new Error('Chat API error ' + response.status);

      var reader      = response.body.getReader();
      var decoder     = new TextDecoder();
      var streamStarted = false;

      while (true) {
        var result = await reader.read();
        if (result.done) break;

        if (!streamStarted) {
          streamStarted = true;
          setTyping(false);
        }

        var lines = decoder.decode(result.value, { stream: true }).split('\n');
        for (var i = 0; i < lines.length; i++) {
          var line = lines[i];
          if (!line.startsWith('data: ')) continue;
          var raw = line.slice(6).trim();
          if (raw === '[DONE]') break;
          try {
            var evt = JSON.parse(raw);
            if (evt.type === 'content_block_delta' && evt.delta && evt.delta.type === 'text_delta') {
              accumulated += evt.delta.text;
              bubble.textContent = accumulated.replace(/\[ROUTE:[^\]]+\]\s*$/, '').trim();
              chatMessages.scrollTop = chatMessages.scrollHeight;
            }
          } catch (_e) { /* skip malformed SSE */ }
        }
      }

      var routeMatch = accumulated.match(/\[ROUTE:([a-z_]+)\]/);
      var cleanText  = accumulated.replace(/\[ROUTE:[^\]]+\]/, '').trim();
      bubble.textContent = cleanText;
      messages.push({ role: 'assistant', content: cleanText });
      fireGtm('chat_message_received');
      trackEvent('chat_message_sent', { role: 'assistant', message: cleanText });

      if (routeMatch) {
        var routeKey = routeMatch[1];
        fireGtm('chat_routed', { route: routeKey });
        // Show a route card with explanation + button instead of auto-routing
        showRouteCard(routeKey);
      }

    } catch (err) {
      if (err && err.name === 'AbortError') return;
      bubble.textContent = 'Connection issue — please call us at 502-619-5198.';
      bubble.classList.add('ds-msg-error');
      console.error('Chat error:', err);
    } finally {
      setTyping(false);
      setChatDisabled(false);
      chatInput.focus();
      streamController = null;
    }
  }

  chatForm.addEventListener('submit', function (e) {
    e.preventDefault();
    var text = chatInput.value.trim();
    if ((!text && pendingImages.length === 0) || chatInput.disabled) return;
    chatInput.value = '';
    chatInput.style.height = 'auto';
    sendChatMessage(text);
  });

  // ── Route card (shown after AI diagnoses) ────────────────────────────────────
  var ROUTE_LABELS = {
    spring_repair: 'Spring Repair',
    cable_roller: 'Cable & Roller Repair',
    opener_repair: 'Opener Repair',
    opener_replace: 'New Opener Install',
    tuneup: 'Tune-Up & Maintenance',
    rep: 'Talk to a Specialist',
  };
  var ROUTE_DESCRIPTIONS = {
    spring_repair: 'It sounds like you need a spring repair or replacement. We handle these daily — most are fixed same-day. Take a look at our pricing options below.',
    cable_roller: 'Based on what you described, this looks like a cable or roller issue. These are quick fixes we do all the time. Check out our repair packages.',
    opener_repair: 'Your opener likely needs a repair or diagnostic. We can usually fix it on the first visit. See our repair options and pricing.',
    opener_replace: 'It sounds like your opener may need to be replaced. We install top-rated Chamberlain openers with professional installation. See our options.',
    tuneup: 'Sounds like your door could use a tune-up. Regular maintenance prevents costly repairs down the road. Check out our maintenance packages.',
    rep: 'For this type of work, we recommend talking to one of our specialists who can give you personalized advice and an exact quote.',
  };

  function showRouteCard(routeKey) {
    var label = ROUTE_LABELS[routeKey] || 'Service';
    var desc = ROUTE_DESCRIPTIONS[routeKey] || 'We can help with that. Take a look at our options.';
    var btnText = routeKey === 'rep' ? 'Talk to Our Team' : 'View ' + label + ' Pricing';

    var card = document.createElement('div');
    card.className = 'ds-route-card';
    card.innerHTML =
      '<div class="ds-route-card-text">' + esc(desc) + '</div>' +
      '<button class="ds-route-card-btn" type="button">' +
        esc(btnText) +
        ' <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>' +
      '</button>';

    chatMessages.appendChild(card);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    card.querySelector('.ds-route-card-btn').addEventListener('click', function () {
      if (routeKey === 'rep') {
        goTo('rep');
      } else if (routeKey === 'opener_replace') {
        selectedServiceId = 'opener_replace';
        goTo('opener_guide');
      } else {
        selectedServiceId = routeKey;
        goTo('questions');
      }
    });
  }

  // ── Textarea auto-resize ────────────────────────────────────────────────────
  chatInput.addEventListener('input', function () {
    chatInput.style.height = 'auto';
    chatInput.style.height = Math.min(chatInput.scrollHeight, 120) + 'px';
  });
  // Submit on Enter (Shift+Enter for new line)
  chatInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      chatForm.dispatchEvent(new Event('submit', { cancelable: true }));
    }
  });

  // ── Analytics session id (per browser tab/session) ───────────────────────────
  var ANALYTICS_SESSION_KEY = 'ds_analytics_session';
  function getAnalyticsSession() {
    try {
      var s = sessionStorage.getItem(ANALYTICS_SESSION_KEY);
      if (!s) {
        s = 's_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 8);
        sessionStorage.setItem(ANALYTICS_SESSION_KEY, s);
      }
      return s;
    } catch (_) { return 's_anon'; }
  }

  // POST analytics event to /api/analytics. Uses sendBeacon when possible
  // so unload events (drop-off) survive the page navigation. Fire-and-forget.
  function trackEvent(type, data) {
    try {
      var payload = Object.assign({
        type: type,
        sessionId: getAnalyticsSession(),
        screen: currentScreen,
        serviceId: selectedServiceId || undefined,
      }, data || {});
      var body = JSON.stringify(payload);
      var url = '/api/analytics';
      if (navigator.sendBeacon) {
        var blob = new Blob([body], { type: 'application/json' });
        navigator.sendBeacon(url, blob);
      } else {
        fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: body,
          keepalive: true,
        }).catch(function () { /* swallow */ });
      }
    } catch (_) { /* never break the widget on analytics */ }
  }

  // ── GTM + analytics ──────────────────────────────────────────────────────────
  function fireGtm(event, data) {
    if (typeof window !== 'undefined' && Array.isArray(window.dataLayer)) {
      window.dataLayer.push(Object.assign({ event: 'ds_' + event }, data || {}));
    }
    // Mirror every GTM event to the durable analytics store so we can see
    // funnels, drop-offs, and per-session journeys in the admin dashboard.
    trackEvent(event, data);
  }

  // Drop-off / abandonment beacon
  if (typeof window !== 'undefined') {
    window.addEventListener('beforeunload', function () {
      trackEvent('drop_off', { lastScreen: currentScreen });
    });
    document.addEventListener('visibilitychange', function () {
      if (document.visibilityState === 'hidden') {
        trackEvent('visibility_hidden', { lastScreen: currentScreen });
      }
    });
  }

  // ── XSS helpers ──────────────────────────────────────────────────────────────
  function esc(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }
  function escAttr(str) { return esc(str); }

  // ── Wire controls ─────────────────────────────────────────────────────────────
  renderServiceCards();
  syncConfigFromApi();
  startConfigAutoRefresh();

  window.addEventListener('focus', function () { syncConfigFromApi(); });
  document.addEventListener('visibilitychange', function () {
    if (document.visibilityState === 'visible') syncConfigFromApi();
  });

  trigger.addEventListener('click', openPanel);
  closeBtn.addEventListener('click', closePanel);
  backBtn.addEventListener('click', goBack);

  document.getElementById('ds-go-service').addEventListener('click', function () {
    fireGtm('quote_path_selected');
    goTo('service');
  });

  document.getElementById('ds-go-chat').addEventListener('click', function () {
    fireGtm('chat_path_selected');
    goTo('chat');
  });

  // ── Proactive nudge tooltip ─────────────────────────────────────────────────
  var nudge = document.getElementById('ds-nudge');
  var nudgeClose = document.getElementById('ds-nudge-close');
  if (nudge && !sessionStorage.getItem('ds_nudge_dismissed')) {
    setTimeout(function () {
      if (!isOpen) {
        nudge.setAttribute('data-visible', 'true');
        fireGtm('nudge_shown');
      }
    }, 8000);
  }
  if (nudgeClose) {
    nudgeClose.addEventListener('click', function (e) {
      e.stopPropagation();
      nudge.setAttribute('data-visible', 'false');
      sessionStorage.setItem('ds_nudge_dismissed', '1');
    });
  }
  // Also hide nudge when widget opens
  var origOpen = openPanel;
  openPanel = function () {
    if (nudge) nudge.setAttribute('data-visible', 'false');
    sessionStorage.setItem('ds_nudge_dismissed', '1');
    origOpen();
  };

  // ── Embed mode ───────────────────────────────────────────────────────────────
  var isEmbed = new URLSearchParams(window.location.search).get('embed') === '1';
  if (isEmbed) {
    // Hide trigger + nudge — parent page handles those
    trigger.style.display = 'none';
    if (nudge) nudge.style.display = 'none';
    // Auto-open panel
    openPanel();
    // Override close to message parent FIRST, then close panel
    var origClose = closePanel;
    closePanel = function () {
      // Send close message to parent immediately so overlay hides
      // before the panel animation reveals the white background
      if (window.parent !== window) {
        window.parent.postMessage('ds-widget-close', '*');
      }
      origClose();
    };
    // Panel should be full-size in embed mode, covering all page content
    panel.style.position = 'fixed';
    panel.style.bottom = '0';
    panel.style.right = '0';
    panel.style.left = '0';
    panel.style.top = '0';
    panel.style.width = '100%';
    panel.style.maxHeight = '100%';
    panel.style.borderRadius = '0';
    panel.style.zIndex = '99999';
    panel.style.transform = 'none';
    panel.style.opacity = '1';
    panel.style.pointerEvents = 'auto';
  }

})();
</script>
