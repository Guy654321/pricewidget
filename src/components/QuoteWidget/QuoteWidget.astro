---
import { SERVICES, CONTACT } from './quoteData';
import type { ServiceConfig } from './quoteData';
import './QuoteWidget.css';
import fs from 'node:fs';
import path from 'node:path';

// Read editable JSON config for dynamic data (prices, tiers, qualifiers)
// Falls back to quoteData.ts if JSON doesn't exist
let jsonServices: any[] | null = null;
let jsonContact: any | null = null;
let jsonTrustSignals: any | null = null;
let jsonAvailability: any | null = null;
let jsonPriceFlow: string = 'price-first';

try {
  const configPath = path.join(process.cwd(), 'public/config/services.json');
  const raw = fs.readFileSync(configPath, 'utf-8');
  const jsonConfig = JSON.parse(raw);
  jsonServices = jsonConfig.services;
  jsonContact = jsonConfig.contact;
  jsonTrustSignals = jsonConfig.trustSignals || null;
  jsonAvailability = jsonConfig.availability || null;
  jsonPriceFlow = jsonConfig.priceFlow || 'price-first';
} catch {
  // JSON config not found — will use quoteData.ts
}

// Static template data (icons, service cards) always from quoteData.ts
// Dynamic JS data (tiers, prices, qualifiers) from JSON if available
const servicesData = jsonServices || SERVICES.map((s: ServiceConfig) => ({
  id: s.id,
  label: s.label,
  subtitle: s.subtitle,
  description: s.description,
  qualifier: s.qualifier,
  tiers: s.tiers,
}));

const contactData = jsonContact || {
  louisville: CONTACT.louisville,
  lexington:  CONTACT.lexington,
  nky:        CONTACT.nky,
};

const trustSignals = jsonTrustSignals || { enabled: false };
const availability = jsonAvailability || { enabled: false };
---

<!-- ─── Floating trigger button ──────────────────────────────────────────────── -->
<button
  class="ds-widget ds-trigger"
  id="ds-trigger"
  aria-haspopup="dialog"
  aria-expanded="false"
  aria-controls="ds-panel"
  data-pulse="true"
  type="button"
>
  <svg class="ds-trigger-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
    <path d="M7 2v11h3v9l7-12h-4l4-8z"/>
  </svg>
  <span>Instant Quote</span>
</button>

<!-- Nudge tooltip -->
<div class="ds-widget ds-trigger-nudge" id="ds-nudge" data-visible="false">
  Need a quick quote? Takes 30 seconds
  <button class="ds-nudge-close" id="ds-nudge-close" type="button" aria-label="Dismiss">&times;</button>
</div>

<!-- ─── Widget panel ─────────────────────────────────────────────────────────── -->
<div
  id="ds-panel"
  class="ds-widget ds-panel"
  role="dialog"
  aria-modal="true"
  aria-label="Derby Strong Instant Quote"
  data-open="false"
  data-screen="home"
>

  <!-- SR announcer -->
  <div id="ds-announcer" class="ds-sr-announcer" aria-live="polite" aria-atomic="true"></div>

  <!-- ── Header ──────────────────────────────────────────────────────────────── -->
  <div class="ds-header ds-widget">
    <button class="ds-icon-btn" id="ds-back" aria-label="Go back" type="button" hidden>
      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/>
      </svg>
    </button>

    <div class="ds-header-logo">
      <img src="/images/derby-strong-logo.png" alt="Derby Strong" class="ds-header-logo-img" width="30" height="30" decoding="async" fetchpriority="low" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
      <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="color:#FFB703;flex-shrink:0;display:none">
        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3l5 3v8H7V9l5-3z"/>
      </svg>
      <div>
        <div class="ds-header-wordmark">Derby Strong</div>
        <div class="ds-header-breadcrumb" id="ds-breadcrumb">Garage Doors</div>
      </div>
    </div>

    <button class="ds-icon-btn" id="ds-close" aria-label="Close widget" type="button">
      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
      </svg>
    </button>
  </div>

  <!-- Step bar (visible on service / questions / tiers) -->
  <div class="ds-step-bar" id="ds-step-bar" hidden>
    <div class="ds-step-dot" id="ds-step-1"></div>
    <div class="ds-step-dot" id="ds-step-2"></div>
    <div class="ds-step-dot" id="ds-step-3"></div>
  </div>

  <!-- ── Scrollable body ──────────────────────────────────────────────────────── -->
  <div class="ds-body">

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- SCREEN: Home                                                             -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="ds-screen" data-screen="home">
      <div class="ds-home-body">
        <p class="ds-home-headline">Get an Instant Quote</p>
        <p class="ds-home-sub">Louisville · Lexington · Northern KY</p>
        {availability.enabled && availability.message && (
          <div class="ds-availability-badge">
            <span class="ds-availability-dot" aria-hidden="true"></span>
            {availability.message}
          </div>
        )}

        <div class="ds-main-choices">

          <button class="ds-main-choice" id="ds-go-service" type="button">
            <div class="ds-main-choice-icon ds-main-choice-icon--teal" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
              </svg>
            </div>
            <div class="ds-main-choice-text">
              <span class="ds-main-choice-title">Get an instant quote</span>
              <span class="ds-main-choice-desc">Spring, opener, cable, tune-up &amp; more</span>
            </div>
            <svg class="ds-main-choice-arrow" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
            </svg>
          </button>

          <button class="ds-main-choice" id="ds-go-chat" type="button">
            <div class="ds-main-choice-icon ds-main-choice-icon--amber" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
              </svg>
            </div>
            <div class="ds-main-choice-text">
              <span class="ds-main-choice-title">Chat with our agent</span>
              <span class="ds-main-choice-desc">Describe the issue — we'll figure it out</span>
            </div>
            <svg class="ds-main-choice-arrow" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
            </svg>
          </button>

        </div>
      </div>

      <div class="ds-phone-bar">
        <span class="ds-phone-bar-label">Call us:</span>
        <a href={contactData.louisville.href} class="ds-phone-link">Louisville&nbsp;{contactData.louisville.display}</a>
        <span class="ds-phone-sep" aria-hidden="true">·</span>
        <a href={contactData.lexington.href} class="ds-phone-link">Lexington&nbsp;{contactData.lexington.display}</a>
        <span class="ds-phone-sep" aria-hidden="true">·</span>
        <a href={contactData.nky.href} class="ds-phone-link">NKY&nbsp;{contactData.nky.display}</a>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- SCREEN: Service Select                                                   -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="ds-screen" data-screen="service">
      <div class="ds-svc-screen-inner">
        <p class="ds-screen-title">What can we help with?</p>

        <div class="ds-service-grid" id="ds-service-grid">

          {SERVICES.map((svc) => (
            <button class="ds-service-card" data-service={svc.id} type="button" aria-label={svc.label}>
              <span class="ds-service-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d={svc.icon}/>
                </svg>
              </span>
              <span class="ds-service-name">{svc.label}</span>
            </button>
          ))}

          <button class="ds-service-card" data-service="new_door" type="button" aria-label="New Door Installation">
            <span class="ds-service-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3l5 3v8H7V9l5-3z"/>
              </svg>
            </span>
            <span class="ds-service-name">New Door</span>
            <span class="ds-service-badge-sm">Specialist</span>
          </button>

          <button class="ds-service-card" data-service="something_else" type="button" aria-label="Something else — chat with AI">
            <span class="ds-service-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 12h-2v-2h2v2zm0-4h-2V6h2v4z"/>
              </svg>
            </span>
            <span class="ds-service-name">Not Sure? Chat with AI</span>
          </button>

        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- SCREEN: Opener Guide (visual opener-type selector)                       -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="ds-screen" data-screen="opener_guide">
      <div class="ds-opener-inner">
        <p class="ds-screen-title">What type of opener?</p>
        <p class="ds-screen-sub">Pick one — we'll show you pricing right away</p>

        <div class="ds-opener-cards" id="ds-opener-cards">
          <!-- Populated by JS renderOpenerGuide() from config data -->
        </div>

        <!-- Explanation panel — shown when "Help Me Choose" is selected -->
        <div class="ds-opener-explain" id="ds-opener-explain" data-visible="false">
          <p class="ds-opener-explain-title">Here's how to decide:</p>
          <div class="ds-opener-explain-row">
            <span class="ds-opener-explain-badge" style="background:#dcfce7;color:#166534;">Budget</span>
            <p class="ds-opener-explain-text">Chain Drive is the most affordable. Belt Drive costs a bit more but runs much quieter.</p>
          </div>
          <div class="ds-opener-explain-row">
            <span class="ds-opener-explain-badge" style="background:#fef3c7;color:#92400e;">Location</span>
            <p class="ds-opener-explain-text">Attached garage with living space above? Belt or Smart Drive greatly reduces noise transfer.</p>
          </div>
          <div class="ds-opener-explain-row">
            <span class="ds-opener-explain-badge" style="background:#e0e7ff;color:#3730a3;">Smart Home</span>
            <p class="ds-opener-explain-text">Want to open from your phone or see who's coming and going? Smart Belt Drive includes WiFi &amp; camera.</p>
          </div>
          <div class="ds-questions-footer" style="margin-top:12px">
            <button class="ds-chat-link-btn" id="ds-opener-chat-btn" type="button">
              <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
              </svg>
              Chat with our AI instead
            </button>
          </div>
        </div>

      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- SCREEN: Qualifier Questions                                              -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="ds-screen" data-screen="questions">
      <div class="ds-questions-inner" id="ds-questions-body">
        <!-- Populated by JS renderQuestions() -->
      </div>
      <div class="ds-questions-footer" id="ds-questions-footer" style="display:none">
        <button
          class="ds-cta-btn"
          id="ds-see-pricing"
          type="button"
          disabled
          aria-disabled="true"
        >
          See my pricing
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- SCREEN: Opener Info (contextual explanation before routing)              -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="ds-screen" data-screen="opener_info">
      <div class="ds-opener-info-inner" id="ds-opener-info-body">
        <!-- Populated by JS renderOpenerInfo() -->
      </div>
      <div class="ds-questions-footer">
        <button class="ds-cta-btn" id="ds-opener-info-cta" type="button">
          See My Pricing
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- SCREEN: Pricing Tiers                                                   -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="ds-screen" data-screen="tiers">
      <div class="ds-tiers-inner">
        <div class="ds-tiers-header">
          <div class="ds-tiers-svc-label" id="ds-tiers-service-label"></div>
          <div class="ds-tiers-title">Choose your package</div>
        </div>
        <div class="ds-tier-grid" id="ds-tier-grid">
          <!-- Populated by JS renderTiers() -->
        </div>
      </div>
      <p class="ds-tiers-disclaimer">
        Price ranges are estimates. Final quote confirmed on-site. All work guaranteed.
      </p>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- SCREEN: AI Chat                                                          -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="ds-screen" data-screen="chat" style="position:relative">

      <!-- Drop zone overlay (shown during drag) -->
      <div class="ds-drop-zone" id="ds-drop-zone" data-active="false" aria-hidden="true">
        <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="opacity:0.6;margin-right:8px">
          <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11zM8 15h8v2H8zm0-4h8v2H8zm0-4h5v2H8z"/>
        </svg>
        Drop photo here
      </div>

      <!-- Messages -->
      <div
        class="ds-chat-messages"
        id="ds-chat-messages"
        aria-live="polite"
        aria-relevant="additions"
        role="log"
        aria-label="Chat messages"
      ></div>

      <!-- Typing indicator -->
      <div
        class="ds-typing-indicator ds-widget"
        id="ds-typing"
        aria-hidden="true"
        data-visible="false"
      >
        <div class="ds-typing-dot"></div>
        <div class="ds-typing-dot"></div>
        <div class="ds-typing-dot"></div>
      </div>

      <!-- Pending image thumbnails -->
      <div class="ds-img-pending-row" id="ds-img-pending-row"></div>

      <!-- Chat form -->
      <form class="ds-chat-form" id="ds-chat-form" autocomplete="off" novalidate>
        <!-- Hidden file input -->
        <input
          type="file"
          id="ds-file-input"
          accept="image/*"
          multiple
          aria-hidden="true"
          tabindex="-1"
          style="display:none"
        />
        <!-- Attach button -->
        <button
          class="ds-attach-btn"
          id="ds-attach-btn"
          type="button"
          aria-label="Attach photo"
          data-has-image="false"
        >
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5a2.5 2.5 0 0 1 5 0v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5a2.5 2.5 0 0 0 5 0V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z"/>
          </svg>
        </button>
        <textarea
          class="ds-chat-input"
          id="ds-chat-input"
          placeholder="Describe your door problem…"
          aria-label="Type your message"
          maxlength="500"
          autocomplete="off"
          rows="1"
        ></textarea>
        <button class="ds-chat-send" type="submit" aria-label="Send message">
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
          </svg>
        </button>
      </form>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- SCREEN: Speak to a Representative                                        -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="ds-screen" data-screen="rep">
      <div class="ds-rep-inner">
        <p class="ds-screen-title">Talk to Our Team</p>
        <p class="ds-rep-intro">
          For door replacements and installations, we want to measure and show you options
          in person. It's free and there's no pressure — just great advice.
        </p>
        <div class="ds-rep-calls">
          {Object.values(contactData).map((market: any) => (
            <a
              href={market.href}
              class="ds-rep-call-btn"
              aria-label={`Call ${market.label}: ${market.display}`}
            >
              <span class="ds-rep-call-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                </svg>
              </span>
              <div class="ds-rep-call-info">
                <span class="ds-rep-call-region">{market.label}</span>
                <span class="ds-rep-call-number">{market.display}</span>
              </div>
              <svg class="ds-rep-call-chevron" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

  </div><!-- /.ds-body -->
</div><!-- /#ds-panel -->

<!-- ─── Client-side widget logic ──────────────────────────────────────────────── -->
<script define:vars={{ servicesData, contactData, trustSignals, availability, priceFlow: jsonPriceFlow }} is:inline>
(function () {
  'use strict';

  var SERVICES      = servicesData;
  var CONTACT       = contactData;
  var PRICE_FLOW    = priceFlow || 'price-first';
  var capturedLead  = null; // Stores { name, phone, zip } when info-first flow is used
  var TRUST_SIGNALS = trustSignals;
  var AVAILABILITY  = availability;
  var LOCAL_CONFIG_KEY = 'derby_services_config_v1';
  var CONFIG_ENDPOINT = '/api/config';
  var CONFIG_REFRESH_MS = 15000;
  var configRefreshTimer = null;
  var lastConfigSignature = '';

  // ── DOM refs ────────────────────────────────────────────────────────────────
  var panel          = document.getElementById('ds-panel');
  var trigger        = document.getElementById('ds-trigger');
  var closeBtn       = document.getElementById('ds-close');
  var backBtn        = document.getElementById('ds-back');
  var breadcrumb     = document.getElementById('ds-breadcrumb');
  var stepBar        = document.getElementById('ds-step-bar');
  var step1          = document.getElementById('ds-step-1');
  var step2          = document.getElementById('ds-step-2');
  var step3          = document.getElementById('ds-step-3');
  var announcer      = document.getElementById('ds-announcer');
  var serviceGrid    = document.getElementById('ds-service-grid');
  var questionsBody  = document.getElementById('ds-questions-body');
  var questionsFooter = document.getElementById('ds-questions-footer');
  var seePricingBtn  = document.getElementById('ds-see-pricing');
  var tierGrid       = document.getElementById('ds-tier-grid');
  var tiersLabel     = document.getElementById('ds-tiers-service-label');
  var chatMessages   = document.getElementById('ds-chat-messages');
  var typingEl       = document.getElementById('ds-typing');
  var chatForm       = document.getElementById('ds-chat-form');
  var chatInput      = document.getElementById('ds-chat-input');
  var fileInput      = document.getElementById('ds-file-input');
  var attachBtn      = document.getElementById('ds-attach-btn');
  var imgPendingRow  = document.getElementById('ds-img-pending-row');
  var dropZone       = document.getElementById('ds-drop-zone');
  var openerExplain   = document.getElementById('ds-opener-explain');
  var openerCardsEl   = document.getElementById('ds-opener-cards');
  var openerChatBtn   = document.getElementById('ds-opener-chat-btn');
  var openerInfoBody  = document.getElementById('ds-opener-info-body');
  var openerInfoCta   = document.getElementById('ds-opener-info-cta');

  // ── State ───────────────────────────────────────────────────────────────────
  var currentScreen     = 'home';
  var screenStack       = [];
  var selectedServiceId = null;
  var selectedPill      = null;   // pill label string
  var selectedPillObj   = null;   // full pill object { label, tiers?, action?, redirect? }
  var selectedOpener    = null;   // chain_drive | belt_drive | smart_drive | not_sure
  var openerInfoTarget  = null;   // service ID to route to after opener_info screen
  var openerInfoAge     = null;   // opener age answer for remote pill
  var messages          = [];
  var pendingImages     = [];     // [{dataUrl, mediaType}]
  var isOpen            = false;
  var streamController  = null;
  var greetingShown     = false;

  // ── Screen metadata ─────────────────────────────────────────────────────────
  var SCREEN_BREADCRUMBS = {
    home:         'Garage Doors',
    service:      'Select Service',
    opener_guide: 'Opener Options',
    opener_info:  'Opener Details',
    questions:    'Tell Us More',
    tiers:        'Pricing',
    chat:         'AI Assistant',
    rep:          'Our Team',
  };

  // ── Navigation ──────────────────────────────────────────────────────────────
  function goTo(screen, addToHistory) {
    if (addToHistory !== false && currentScreen !== screen) {
      screenStack.push(currentScreen);
    }
    currentScreen = screen;
    panel.dataset.screen = screen;
    breadcrumb.textContent = SCREEN_BREADCRUMBS[screen] || '';
    backBtn.hidden = screenStack.length === 0;
    updateStepBar(screen);
    announce(SCREEN_BREADCRUMBS[screen]);

    if (screen === 'questions')    renderQuestions();
    if (screen === 'tiers')        renderTiers();
    if (screen === 'chat' && !greetingShown) renderGreeting();
    if (screen === 'opener_guide') resetOpenerGuide();
    if (screen === 'opener_info')  renderOpenerInfo();

    fireGtm('screen_changed', { screen: screen });

    // Tell parent iframe host which screen we're on so it can resize
    if (window.parent !== window) {
      window.parent.postMessage({ type: 'ds-widget-screen', screen: screen }, '*');
    }
  }

  function goBack() {
    var prev = screenStack.pop();
    if (prev) goTo(prev, false);
  }

  // ── Step bar ────────────────────────────────────────────────────────────────
  function updateStepBar(screen) {
    var showSteps = ['service', 'questions', 'tiers'].indexOf(screen) !== -1;
    stepBar.hidden = !showSteps;
    if (!showSteps) return;
    var stepMap = { service: 1, questions: 2, tiers: 3 };
    var active = stepMap[screen] || 0;
    [step1, step2, step3].forEach(function (dot, i) {
      dot.dataset.active = (i + 1 === active)  ? 'true' : 'false';
      dot.dataset.done   = (i + 1 < active)    ? 'true' : 'false';
    });
  }

  // ── SR announcer ────────────────────────────────────────────────────────────
  function announce(msg) {
    announcer.textContent = '';
    setTimeout(function () { announcer.textContent = msg; }, 50);
  }

  // ── Open / Close ────────────────────────────────────────────────────────────
  function openPanel() {
    isOpen = true;
    panel.dataset.open = 'true';
    trigger.setAttribute('aria-expanded', 'true');
    trapFocus(panel);
    fireGtm('widget_opened');
  }

  function closePanel() {
    isOpen = false;
    panel.dataset.open = 'false';
    trigger.setAttribute('aria-expanded', 'false');
    releaseFocus();
    if (streamController) streamController.abort();
  }

  // ── Focus trap ──────────────────────────────────────────────────────────────
  var focusTrapHandler = null;
  var prevFocused      = null;
  var FOCUSABLE = 'button:not([disabled]), [href], input:not([disabled]), select, textarea, [tabindex]:not([tabindex="-1"])';

  function trapFocus(container) {
    prevFocused = document.activeElement;
    focusTrapHandler = function (e) {
      if (e.key !== 'Tab') return;
      var els = Array.from(container.querySelectorAll(FOCUSABLE))
        .filter(function (el) { return el.offsetParent !== null; });
      if (els.length === 0) return;
      var first = els[0], last = els[els.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault(); last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault(); first.focus();
      }
    };
    document.addEventListener('keydown', focusTrapHandler);
    closeBtn.focus();
  }

  function releaseFocus() {
    if (focusTrapHandler) {
      document.removeEventListener('keydown', focusTrapHandler);
      focusTrapHandler = null;
    }
    if (prevFocused && prevFocused.focus) prevFocused.focus();
    prevFocused = null;
  }

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && isOpen) closePanel();
  });

  // ── Pulse animation ─────────────────────────────────────────────────────────
  trigger.addEventListener('animationend', function onPulse() {
    trigger.removeAttribute('data-pulse');
    trigger.removeEventListener('animationend', onPulse);
  });

  // ── Service card routing ─────────────────────────────────────────────────────
  function handleServiceSelection(id) {
    if (!id) return;
    if (id === 'new_door') {
      fireGtm('rep_screen_shown');
      goTo('rep');
      return;
    }
    if (id === 'something_else') {
      fireGtm('chat_path_selected');
      goTo('chat');
      return;
    }
    selectedServiceId = id;
    selectedPill = null;
    fireGtm('service_selected', { service_id: id });
    // Opener replacement gets the visual guide first
    if (id === 'opener_replace') {
      goTo('opener_guide');
    } else {
      goTo('questions');
    }
  }

  if (serviceGrid) {
    serviceGrid.addEventListener('click', function (e) {
      var btn = e.target && e.target.closest ? e.target.closest('[data-service]') : null;
      if (!btn || !serviceGrid.contains(btn)) return;
      handleServiceSelection(btn.getAttribute('data-service'));
    });
  }

  function normalizeTier(tier) {
    if (!tier || typeof tier !== 'object') return tier;
    var out = Object.assign({}, tier);
    if (!out.image) out.image = out.photo || out.photoUrl || out.imageUrl || '';
    if (!out.summary && out.description) out.summary = out.description;
    if (!Array.isArray(out.features)) out.features = [];
    return out;
  }

  function normalizeService(svc) {
    if (!svc || typeof svc !== 'object') return svc;
    var out = Object.assign({}, svc);
    if (!out.id && out.serviceId) out.id = out.serviceId;
    if (!out.label && out.name) out.label = out.name;
    if (!out.description && out.subtitle) out.description = out.subtitle;
    if (!out.subtitle && out.description) out.subtitle = out.description;

    if (!out.qualifier && out.question) {
      out.qualifier = { question: out.question, pills: out.options || [] };
    }
    if (!out.qualifier || typeof out.qualifier !== 'object') {
      out.qualifier = { question: 'Tell us more', pills: [{ label: 'Not sure' }] };
    }
    if (!out.qualifier.question) out.qualifier.question = 'Tell us more';
    if (!Array.isArray(out.qualifier.pills)) out.qualifier.pills = [{ label: 'Not sure' }];
    if (Array.isArray(out.tiers)) out.tiers = out.tiers.map(normalizeTier);
    return out;
  }

  SERVICES = (SERVICES || []).map(normalizeService);

  function renderServiceCards() {
    if (!serviceGrid) return;
    var baseCards = (SERVICES || []).map(function (svc) {
      var iconPath = svc.icon || 'M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3l5 3v8H7V9l5-3z';
      return (
        '<button class="ds-service-card" data-service="' + escAttr(svc.id) + '" type="button" aria-label="' + escAttr(svc.label || svc.id) + '">' +
          '<span class="ds-service-icon" aria-hidden="true">' +
            '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">' +
              '<path d="' + escAttr(iconPath) + '"/>' +
            '</svg>' +
          '</span>' +
          '<span class="ds-service-name">' + esc(svc.label || svc.id) + '</span>' +
        '</button>'
      );
    });

    baseCards.push(
      '<button class="ds-service-card" data-service="new_door" type="button" aria-label="New Door Installation">' +
        '<span class="ds-service-icon" aria-hidden="true">' +
          '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">' +
            '<path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3l5 3v8H7V9l5-3z"/>' +
          '</svg>' +
        '</span>' +
        '<span class="ds-service-name">New Door</span>' +
        '<span class="ds-service-badge-sm">Specialist</span>' +
      '</button>'
    );
    baseCards.push(
      '<button class="ds-service-card" data-service="something_else" type="button" aria-label="Something else — chat with AI">' +
        '<span class="ds-service-icon" aria-hidden="true">' +
          '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">' +
            '<path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 12h-2v-2h2v2zm0-4h-2V6h2v4z"/>' +
          '</svg>' +
        '</span>' +
        '<span class="ds-service-name">Not Sure? Chat with AI</span>' +
      '</button>'
    );

    serviceGrid.innerHTML = baseCards.join('');
  }

  function configSignature(payload) {
    try {
      return JSON.stringify({
        services: payload && payload.services,
        contact: payload && payload.contact,
        trustSignals: payload && payload.trustSignals,
        availability: payload && payload.availability,
        priceFlow: payload && payload.priceFlow
      });
    } catch (_) {
      return '';
    }
  }

  function applyLiveConfig(payload) {
    var nextSig = configSignature(payload);
    var changed = nextSig && nextSig !== lastConfigSignature;
    if (nextSig) lastConfigSignature = nextSig;

    if (payload && Array.isArray(payload.services)) SERVICES = payload.services.map(normalizeService);
    if (payload && payload.contact) CONTACT = payload.contact;
    if (payload && payload.trustSignals) TRUST_SIGNALS = payload.trustSignals;
    if (payload && payload.availability) AVAILABILITY = payload.availability;
    if (payload && payload.priceFlow) PRICE_FLOW = payload.priceFlow;

    renderServiceCards();

    if (!changed) return;
    if (currentScreen === 'questions') renderQuestions();
    if (currentScreen === 'tiers') renderTiers();
    if (currentScreen === 'opener_guide') resetOpenerGuide();
    if (currentScreen === 'opener_info') renderOpenerInfo();
  }

  async function syncConfigFromApi() {
    try {
      var res = await fetch(CONFIG_ENDPOINT, { cache: 'no-store' });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      var payload = await res.json();
      applyLiveConfig(payload);
      try {
        window.localStorage.setItem(LOCAL_CONFIG_KEY, JSON.stringify(payload));
      } catch (_) {}
    } catch (_) {
      try {
        var localRaw = window.localStorage.getItem(LOCAL_CONFIG_KEY);
        if (!localRaw) return;
        var localConfig = JSON.parse(localRaw);
        applyLiveConfig(localConfig);
      } catch (_) {
        // Ignore invalid local fallback data.
      }
    }
  }

  function startConfigAutoRefresh() {
    if (configRefreshTimer) return;
    configRefreshTimer = window.setInterval(function () {
      syncConfigFromApi();
    }, CONFIG_REFRESH_MS);
  }

  // ── Opener Guide (data-driven from config) ───────────────────────────────────
  var OPENER_ICONS = {
    chain: { bg: '#f0f9f9', color: '#0F3D3E', svg: '<path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/>' },
    belt: { bg: '#f8f0ff', color: '#7c3aed', svg: '<path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>' },
    smart: { bg: '#fffbeb', color: '#d97706', svg: '<path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/>' },
    help: { bg: '#f1f5f9', color: '#64748b', svg: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>' },
  };

  function renderOpenerGuide() {
    var svc = SERVICES.find(function (s) { return s.id === 'opener_replace'; });
    if (!svc || !svc.qualifier || !svc.qualifier.pills) return;

    selectedOpener = null;
    openerExplain.dataset.visible = 'false';

    var html = svc.qualifier.pills.map(function (rawPill, idx) {
      var pill = normalizePill(rawPill);
      var iconKey = pill.cardIcon || 'help';
      var iconData = OPENER_ICONS[iconKey] || OPENER_ICONS.help;
      var desc = pill.cardDesc || '';
      var tag = pill.cardTag || '';
      return (
        '<button class="ds-opener-card" data-opener-idx="' + idx + '" type="button">' +
          '<div class="ds-opener-card-icon" style="background:' + iconData.bg + ';color:' + iconData.color + ';" aria-hidden="true">' +
            '<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">' + iconData.svg + '</svg>' +
          '</div>' +
          '<div class="ds-opener-card-text">' +
            '<div class="ds-opener-card-title">' + esc(pill.label) + '</div>' +
            (desc ? '<div class="ds-opener-card-desc">' + esc(desc) + '</div>' : '') +
            (tag ? '<div class="ds-opener-card-tag">' + esc(tag) + '</div>' : '') +
          '</div>' +
        '</button>'
      );
    }).join('');

    openerCardsEl.innerHTML = html;

    // Wire click handlers — auto-advance on click
    openerCardsEl.querySelectorAll('.ds-opener-card').forEach(function (card) {
      card.addEventListener('click', function () {
        var idx = parseInt(card.getAttribute('data-opener-idx'), 10);
        var pill = normalizePill(svc.qualifier.pills[idx]);

        // Highlight
        openerCardsEl.querySelectorAll('.ds-opener-card').forEach(function (c) {
          c.dataset.selected = 'false';
        });
        card.dataset.selected = 'true';

        // "Help Me Choose" / explain action
        if (pill.action === 'explain') {
          openerExplain.dataset.visible = 'true';
          selectedOpener = 'not_sure';
          return;
        }

        openerExplain.dataset.visible = 'false';
        selectedOpener = pill.label;
        selectedPillObj = pill;
        selectedServiceId = 'opener_replace';
        selectedPill = pill.label;

        // Auto-advance to tiers after brief visual feedback
        setTimeout(function () { goToTiersOrCapture(); }, 200);
      });
    });
  }

  function resetOpenerGuide() {
    renderOpenerGuide();
  }

  openerChatBtn.addEventListener('click', function () {
    fireGtm('chat_path_selected');
    goTo('chat');
  });

  // ── Pill helpers ─────────────────────────────────────────────────────────────
  function normalizePill(p) {
    return typeof p === 'string' ? { label: p } : p;
  }

  function findPillObj(svc, label) {
    for (var i = 0; i < svc.qualifier.pills.length; i++) {
      var pill = normalizePill(svc.qualifier.pills[i]);
      if (pill.label === label) return pill;
    }
    return null;
  }

  // ── Questions screen ─────────────────────────────────────────────────────────
  function renderQuestions() {
    var svc = SERVICES.find(function (s) { return s.id === selectedServiceId; });
    if (!svc) return;

    questionsBody.innerHTML =
      '<p class="ds-question-text">' + esc(svc.qualifier.question) + '</p>' +
      '<p class="ds-question-sub">Select one option below</p>' +
      '<div class="ds-pill-group" role="group" aria-label="Answer options">' +
      svc.qualifier.pills.map(function (p) {
        var pill = normalizePill(p);
        return '<button class="ds-pill" data-pill="' + escAttr(pill.label) + '" type="button" aria-pressed="false">' + esc(pill.label) + '</button>';
      }).join('') +
      '</div>';

    selectedPill = null;
    selectedPillObj = null;

    // Check if any pill has an intermediate action (redirect/info)
    // If ALL pills go directly to tiers, show the "See my pricing" button
    var hasIntermediateActions = svc.qualifier.pills.some(function (p) {
      var pill = normalizePill(p);
      return pill.action === 'redirect' || pill.action === 'info';
    });

    // Show footer with button when this is the last step before tiers
    questionsFooter.style.display = 'flex';
    seePricingBtn.disabled = true;
    seePricingBtn.setAttribute('aria-disabled', 'true');

    questionsBody.querySelectorAll('.ds-pill').forEach(function (pill) {
      pill.addEventListener('click', function () {
        questionsBody.querySelectorAll('.ds-pill').forEach(function (p) {
          p.classList.remove('ds-pill--active');
          p.setAttribute('aria-pressed', 'false');
        });
        pill.classList.add('ds-pill--active');
        pill.setAttribute('aria-pressed', 'true');
        selectedPill = pill.getAttribute('data-pill');
        selectedPillObj = findPillObj(svc, selectedPill);

        // If this pill has an intermediate action, auto-advance (one click)
        if (selectedPillObj && (selectedPillObj.action === 'redirect' || selectedPillObj.action === 'info')) {
          setTimeout(function () { advanceFromPill(); }, 200);
          return;
        }

        // Otherwise enable the "See my pricing" button (last step before tiers)
        seePricingBtn.disabled = false;
        seePricingBtn.removeAttribute('aria-disabled');
      });
    });
  }

  seePricingBtn.addEventListener('click', function () {
    if (!selectedPill) return;
    advanceFromPill();
  });

  function advanceFromPill() {
    if (!selectedPill) return;

    // Check pill-level action (redirect or info screen)
    if (selectedPillObj) {
      if (selectedPillObj.action === 'redirect' && selectedPillObj.redirect) {
        var target = selectedPillObj.redirect;
        if (target === 'opener_replace') {
          openerInfoTarget = 'opener_replace';
          goTo('opener_info');
        } else {
          selectedServiceId = target;
          selectedPill = null;
          selectedPillObj = null;
          goTo('questions');
        }
        return;
      }
      if (selectedPillObj.action === 'info') {
        openerInfoTarget = null;
        goTo('opener_info');
        return;
      }
    }

    goToTiersOrCapture();
  }

  // Centralized transition to tiers screen — respects info-first flow
  function goToTiersOrCapture() {
    if (PRICE_FLOW === 'info-first' && !capturedLead) {
      showLeadCaptureForm(function () { goTo('tiers'); });
    } else {
      goTo('tiers');
    }
  }

  // ── Opener Info screen ───────────────────────────────────────────────────────
  function renderOpenerInfo() {
    openerInfoAge = null;
    openerInfoCta.disabled = false;
    openerInfoCta.removeAttribute('aria-disabled');

    // Data-driven redirect (motor burned out, etc.)
    if (selectedPillObj && selectedPillObj.action === 'redirect' && selectedPillObj.redirect === 'opener_replace') {
      // Motor is dead — explain and route to replacement
      openerInfoTarget = 'opener_replace';
      openerInfoCta.innerHTML = 'View Replacement Options <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>';
      openerInfoBody.innerHTML =
        '<div class="ds-opener-info-icon ds-opener-info-icon--warning" aria-hidden="true">' +
          '<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>' +
        '</div>' +
        '<div class="ds-opener-info-title">Your opener motor is likely burned out</div>' +
        '<div class="ds-opener-info-text">' +
          'When an opener hums but the door won\'t move, it usually means the motor or gear assembly has failed. In most cases, this isn\'t cost-effective to repair.' +
        '</div>' +
        '<div class="ds-opener-info-highlight">' +
          '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>' +
          '<span>Replacing the opener is usually the better option — you get a warranty, modern features, and reliable operation for years to come.</span>' +
        '</div>';
    } else if (selectedPillObj && selectedPillObj.action === 'info') {
      // Ask opener age to decide repair vs replace
      openerInfoTarget = null;
      openerInfoCta.disabled = true;
      openerInfoCta.setAttribute('aria-disabled', 'true');
      openerInfoCta.innerHTML = 'See My Pricing <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>';
      openerInfoBody.innerHTML =
        '<div class="ds-opener-info-icon ds-opener-info-icon--info" aria-hidden="true">' +
          '<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>' +
        '</div>' +
        '<div class="ds-opener-info-title">How old is your opener?</div>' +
        '<div class="ds-opener-info-text">' +
          'The age of your opener helps us recommend the best fix. Newer openers usually just need reprogramming, while older ones may need a full replacement.' +
        '</div>' +
        '<div class="ds-opener-age-group">' +
          '<button class="ds-pill" data-age="new" type="button" aria-pressed="false">Less than 10 years old</button>' +
          '<button class="ds-pill" data-age="old" type="button" aria-pressed="false">10+ years old</button>' +
          '<button class="ds-pill" data-age="unsure" type="button" aria-pressed="false">Not sure</button>' +
        '</div>' +
        '<div class="ds-opener-info-highlight ds-opener-info-highlight--blue" id="ds-opener-age-tip" style="display:none">' +
          '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>' +
          '<span id="ds-opener-age-tip-text"></span>' +
        '</div>';

      // Wire age pill clicks
      openerInfoBody.querySelectorAll('[data-age]').forEach(function (pill) {
        pill.addEventListener('click', function () {
          openerInfoBody.querySelectorAll('[data-age]').forEach(function (p) {
            p.classList.remove('ds-pill--active');
            p.setAttribute('aria-pressed', 'false');
          });
          pill.classList.add('ds-pill--active');
          pill.setAttribute('aria-pressed', 'true');
          openerInfoAge = pill.getAttribute('data-age');

          var tip = document.getElementById('ds-opener-age-tip');
          var tipText = document.getElementById('ds-opener-age-tip-text');
          tip.style.display = 'flex';

          if (openerInfoAge === 'new') {
            openerInfoTarget = 'opener_repair';
            tipText.textContent = 'Great news — newer openers can usually be fixed with a simple repair or reprogramming. We\'ll get your remote working again.';
            openerInfoCta.innerHTML = 'View Repair Options <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>';
          } else if (openerInfoAge === 'old') {
            openerInfoTarget = 'opener_replace';
            tipText.textContent = 'For openers over 10 years old, replacement remotes are often unavailable. A new opener gives you modern remotes, WiFi, and a warranty.';
            openerInfoCta.innerHTML = 'View Replacement Options <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>';
          } else {
            openerInfoTarget = 'opener_repair';
            tipText.textContent = 'No worries — our technician will assess your opener on-site and recommend the best option for you.';
            openerInfoCta.innerHTML = 'View Repair Options <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>';
          }

          openerInfoCta.disabled = false;
          openerInfoCta.removeAttribute('aria-disabled');
        });
      });
    }
  }

  openerInfoCta.addEventListener('click', function () {
    if (openerInfoCta.disabled) return;
    var target = openerInfoTarget || 'opener_repair';
    if (target === 'opener_replace') {
      selectedServiceId = 'opener_replace';
      goTo('opener_guide');
    } else {
      selectedServiceId = target;
      goToTiersOrCapture();
    }
  });

  // ── Tiers screen ─────────────────────────────────────────────────────────────
  function renderTiers() {
    var svc = SERVICES.find(function (s) { return s.id === selectedServiceId; });
    if (!svc) return;

    var tierLabelText = svc.label;
    if (selectedPill && selectedPillObj && selectedPillObj.tiers) {
      tierLabelText = selectedPill;
    }
    tiersLabel.textContent = tierLabelText.toUpperCase();
    fireGtm('tier_viewed', { service_id: selectedServiceId });

    // Use pill-specific tiers if available, otherwise service-level defaults
    var activeTiers = svc.tiers;
    if (selectedPillObj && selectedPillObj.tiers && selectedPillObj.tiers.length > 0) {
      activeTiers = selectedPillObj.tiers;
    }

    var slides = activeTiers.map(function (tier, idx) {
      var popularBadge = tier.popular
        ? '<span class="ds-tier-popular-badge">Most Popular</span>' : '';

      var imageHtml = tier.image
        ? '<div class="ds-tier-img-wrap"><img class="ds-tier-img" src="' + escAttr(tier.image) + '" alt="' + escAttr(tier.headline) + '" loading="eager" decoding="async" fetchpriority="high" width="300" height="180"></div>'
        : '';

      var priceRangeHtml = tier.priceRange
        ? '<span class="ds-tier-price-range">' + esc(tier.priceRange) + '</span>'
        : '';

      var summaryHtml = tier.summary
        ? '<div class="ds-tier-summary-text">' + esc(tier.summary) + '</div>'
        : '';

      var warningHtml = tier.upgradeWarning
        ? '<div class="ds-tier-upgrade-warning">' +
            '<svg class="ds-tier-upgrade-warning-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>' +
            '<span>' + esc(tier.upgradeWarning) + '</span>' +
          '</div>'
        : '';

      return (
        '<div class="ds-tier-slide" data-slide="' + idx + '">' +
          '<div class="ds-tier-card" data-tier="' + escAttr(tier.label) + '">' +
            '<div class="ds-tier-header">' +
              '<span>' + esc(tier.label) + '</span>' + popularBadge +
            '</div>' +
            imageHtml +
            '<div class="ds-tier-body">' +
              '<div class="ds-tier-summary">' +
                '<div class="ds-tier-headline">' + esc(tier.headline) + '</div>' +
                summaryHtml +
                '<div class="ds-tier-price-block">' +
                  '<div class="ds-tier-estimate-label">Estimated price</div>' +
                  '<div class="ds-tier-price-row">' +
                    '<span class="ds-tier-price">' + esc(tier.price) + '</span>' +
                    priceRangeHtml +
                  '</div>' +
                  (tier.priceNote ? '<div class="ds-tier-price-sub">' + esc(tier.priceNote) + '</div>' : '') +
                  (tier.financing ? '<div class="ds-tier-financing">' + esc(tier.financing) + '</div>' : '') +
                '</div>' +
              '</div>' +
              warningHtml +
              '<details class="ds-tier-details">' +
                '<summary>What\'s Included</summary>' +
                '<ul class="ds-tier-features">' +
                tier.features.map(function (f) { return '<li>' + esc(f) + '</li>'; }).join('') +
                '</ul>' +
              '</details>' +
              '<button class="ds-tier-book-btn"' +
                ' data-tier="' + escAttr(tier.label) + '"' +
                ' data-service="' + escAttr(selectedServiceId) + '"' +
                ' data-price="' + escAttr(tier.price + (tier.priceRange || '')) + '"' +
                ' type="button">Book In-Home Appointment' +
              '</button>' +
            '</div>' +
          '</div>' +
        '</div>'
      );
    }).join('');

    var dots = activeTiers.map(function (_t, i) {
      return '<button class="ds-tier-dot" data-slide="' + i + '"' +
        ' data-active="' + (i === 0 ? 'true' : 'false') + '"' +
        ' type="button" aria-label="Package ' + (i + 1) + '"></button>';
    }).join('');

    // Trust signals bar
    var trustHtml = '';
    if (TRUST_SIGNALS && TRUST_SIGNALS.enabled) {
      var parts = [];
      if (TRUST_SIGNALS.rating) parts.push('<span class="ds-trust-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="#FFB703"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> ' + esc(TRUST_SIGNALS.rating) + (TRUST_SIGNALS.reviewCount ? ' <span class="ds-trust-sub">(' + esc(TRUST_SIGNALS.reviewCount) + ' reviews)</span>' : '') + '</span>');
      if (TRUST_SIGNALS.jobCount) parts.push('<span class="ds-trust-item">' + esc(TRUST_SIGNALS.jobCount) + ' Jobs</span>');
      if (TRUST_SIGNALS.badges) {
        TRUST_SIGNALS.badges.forEach(function (b) { parts.push('<span class="ds-trust-item">' + esc(b) + '</span>'); });
      }
      trustHtml = '<div class="ds-trust-bar">' + parts.join('<span class="ds-trust-sep" aria-hidden="true">·</span>') + '</div>';
    }

    tierGrid.innerHTML =
      trustHtml +
      '<div class="ds-tier-carousel" id="ds-tier-carousel">' + slides + '</div>' +
      '<div class="ds-tier-dots">' + dots + '</div>';

    // Dot click → scroll to slide
    var carousel = document.getElementById('ds-tier-carousel');
    var dotBtns  = tierGrid.querySelectorAll('.ds-tier-dot');

    dotBtns.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var idx    = parseInt(dot.getAttribute('data-slide'), 10);
        var target = carousel.querySelectorAll('.ds-tier-slide')[idx];
        if (target) carousel.scrollTo({ left: target.offsetLeft, behavior: 'smooth' });
      });
    });

    // Scroll → update active dot
    var scrollTimer;
    carousel.addEventListener('scroll', function () {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function () {
        var slideEls   = Array.from(carousel.querySelectorAll('.ds-tier-slide'));
        var center     = carousel.scrollLeft + carousel.offsetWidth / 2;
        var activeIdx  = 0;
        var minDist    = Infinity;
        slideEls.forEach(function (el, i) {
          var dist = Math.abs(el.offsetLeft + el.offsetWidth / 2 - center);
          if (dist < minDist) { minDist = dist; activeIdx = i; }
        });
        dotBtns.forEach(function (d, i) {
          d.setAttribute('data-active', i === activeIdx ? 'true' : 'false');
        });
      }, 60);
    });

    // Book buttons
    tierGrid.querySelectorAll('.ds-tier-book-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var tier    = btn.getAttribute('data-tier');
        var service = btn.getAttribute('data-service');
        var price   = btn.getAttribute('data-price');
        fireGtm('tier_booked', { service_id: service, tier_name: tier });
        showBookingForm(tier, service, price);
      });
    });
  }

  // ── Booking form modal ───────────────────────────────────────────────────────
  function showBookingForm(tier, service, price) {
    var existing = document.querySelector('.ds-booking-modal');
    if (existing) existing.remove();

    var svc = SERVICES.find(function (s) { return s.id === service; });
    var svcLabel = svc ? svc.label : service;

    var modal = document.createElement('div');
    modal.className = 'ds-booking-modal ds-widget';
    modal.setAttribute('role', 'dialog');
    modal.setAttribute('aria-modal', 'true');
    modal.setAttribute('aria-labelledby', 'ds-booking-title');

    modal.innerHTML =
      '<div class="ds-booking-modal-inner">' +
        '<div class="ds-booking-modal-header">' +
          '<span class="ds-booking-tier-badge" data-tier="' + escAttr(tier) + '">' + esc(tier) + '</span>' +
          '<span class="ds-booking-modal-title" id="ds-booking-title">' + esc(svcLabel) + '</span>' +
        '</div>' +
        '<form class="ds-booking-form" id="ds-booking-form" novalidate>' +
          '<div class="ds-booking-selected">' +
            '<strong>' + esc(tier) + ' Package' + (price && price !== '$XXX' ? ' — ' + esc(price) : '') + '</strong>' +
            "We'll confirm details and schedule your visit." +
          '</div>' +
          '<div class="ds-form-row">' +
            '<label class="ds-form-label" for="ds-book-name">Your name <span>(optional)</span></label>' +
            '<input class="ds-form-input" id="ds-book-name" name="name" type="text" placeholder="Jane Smith" autocomplete="name" />' +
          '</div>' +
          '<div class="ds-form-row">' +
            '<label class="ds-form-label" for="ds-book-phone">Phone number <span>(required)</span></label>' +
            '<input class="ds-form-input" id="ds-book-phone" name="phone" type="tel" placeholder="502-555-0100" autocomplete="tel" inputmode="tel" />' +
            '<span class="ds-form-error-msg" id="ds-book-phone-err">Please enter a valid phone number.</span>' +
          '</div>' +
          '<div class="ds-form-row">' +
            '<label class="ds-form-label" for="ds-book-zip">ZIP code <span>(required)</span></label>' +
            '<input class="ds-form-input" id="ds-book-zip" name="zip" type="text" placeholder="40204" autocomplete="postal-code" inputmode="numeric" maxlength="5" />' +
            '<span class="ds-form-error-msg" id="ds-book-zip-err">Please enter a 5-digit ZIP code.</span>' +
          '</div>' +
          '<div class="ds-consent-row" id="ds-book-consent-row">' +
            '<input type="checkbox" id="ds-book-consent" />' +
            '<label for="ds-book-consent">I agree to be contacted by Derby Strong Garage Doors via phone and text regarding my request.</label>' +
          '</div>' +
        '</form>' +
        '<div class="ds-booking-form-footer">' +
          '<button class="ds-booking-submit" data-tier="' + escAttr(tier) + '" id="ds-booking-submit" type="button">Request Appointment</button>' +
          '<button class="ds-booking-cancel" id="ds-booking-cancel" type="button">Cancel</button>' +
        '</div>' +
      '</div>';

    document.body.appendChild(modal);

    var phoneInput  = modal.querySelector('#ds-book-phone');
    var zipInput    = modal.querySelector('#ds-book-zip');
    var phoneErr    = modal.querySelector('#ds-book-phone-err');
    var zipErr      = modal.querySelector('#ds-book-zip-err');
    var consentBox  = modal.querySelector('#ds-book-consent');
    var consentRow  = modal.querySelector('#ds-book-consent-row');
    var submitBtn   = modal.querySelector('#ds-booking-submit');
    var cancelBtn   = modal.querySelector('#ds-booking-cancel');

    cancelBtn.addEventListener('click', function () { modal.remove(); });
    modal.addEventListener('click', function (e) { if (e.target === modal) modal.remove(); });
    document.addEventListener('keydown', function closeOnEsc(e) {
      if (e.key === 'Escape') { modal.remove(); document.removeEventListener('keydown', closeOnEsc); }
    });
    consentBox.addEventListener('change', function () { consentRow.classList.remove('ds-consent-error'); });

    submitBtn.addEventListener('click', function () {
      var phone = phoneInput.value.trim().replace(/\D/g, '');
      var zip   = zipInput.value.trim();
      var valid = true;

      if (phone.length < 10) {
        phoneInput.classList.add('ds-input-error');
        phoneErr.setAttribute('data-visible', 'true');
        valid = false;
      } else {
        phoneInput.classList.remove('ds-input-error');
        phoneErr.setAttribute('data-visible', 'false');
      }
      if (!/^\d{5}$/.test(zip)) {
        zipInput.classList.add('ds-input-error');
        zipErr.setAttribute('data-visible', 'true');
        valid = false;
      } else {
        zipInput.classList.remove('ds-input-error');
        zipErr.setAttribute('data-visible', 'false');
      }
      if (!consentBox.checked) {
        consentRow.classList.add('ds-consent-error');
        valid = false;
      } else {
        consentRow.classList.remove('ds-consent-error');
      }
      if (!valid) return;

      fireGtm('booking_submitted', { service_id: service, tier_name: tier, zip: zip });

      var nameVal = modal.querySelector('#ds-book-name').value.trim();

      // Save lead to server (non-blocking)
      fetch('/api/bookings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phone: phone,
          name: nameVal || '',
          zip: zip,
          service: svcLabel,
          serviceId: service,
          tier: tier,
          price: price || '',
          source: 'quote',
        }),
      }).catch(function () { /* best-effort */ });

      // Send SMS confirmation (non-blocking)
      fetch('/api/sms', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phone: phone,
          name: nameVal || undefined,
          service: svcLabel,
          tier: tier,
          price: price || undefined,
        }),
      }).catch(function () { /* SMS is best-effort */ });

      // Email notification to owner (non-blocking)
      fetch('/api/notify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phone: phone,
          name: nameVal || '',
          zip: zip,
          service: svcLabel,
          serviceId: service,
          tier: tier,
          price: price || '',
          source: 'quote',
        }),
      }).catch(function () { /* email is best-effort */ });

      showBookingSuccess(modal, tier, svcLabel, price);
    });

    // Pre-fill from captured lead (info-first flow)
    if (capturedLead) {
      if (capturedLead.name)  modal.querySelector('#ds-book-name').value = capturedLead.name;
      if (capturedLead.phone) phoneInput.value = capturedLead.phone;
      if (capturedLead.zip)   zipInput.value = capturedLead.zip;
    }

    phoneInput.focus();
  }

