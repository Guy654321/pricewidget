  function showBookingSuccess(modal, tier, svcLabel, price) {
    var callLinks = Object.values(CONTACT).map(function (m) {
      return '<a href="' + escAttr(m.href) + '" class="ds-rep-call-btn" style="width:100%">' +
        '<span class="ds-rep-call-icon" aria-hidden="true">' +
          '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>' +
        '</span>' +
        '<div class="ds-rep-call-info"><span class="ds-rep-call-region">' + esc(m.label) + '</span><span class="ds-rep-call-number">' + esc(m.display) + '</span></div>' +
