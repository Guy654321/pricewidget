    // ── Leads management ─────────────────────────────────────────
    var allBookings = [];
    var allEvents = [];

    function loadLeads() {
      fetch('/api/bookings')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          allBookings = data;
          renderLeadsTable();
          renderAnalytics();
        })
        .catch(function () {
          document.getElementById('leads-table-wrap').innerHTML = '<p class="admin-leads-empty">Failed to load leads.</p>';
        });
      // Pull analytics events in parallel — failures here don't block the leads view.
      fetch('/api/analytics')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          allEvents = Array.isArray(data) ? data : [];
          renderAnalytics();
        })
        .catch(function () { /* analytics is optional */ });
    }

    function getFilteredBookings() {
      var statusFilter = document.getElementById('leads-status-filter');
      var searchInput = document.getElementById('leads-search');
      var status = statusFilter ? statusFilter.value : '';
      var search = searchInput ? searchInput.value.toLowerCase().trim() : '';
      return allBookings.filter(function (b) {
        if (status && b.status !== status) return false;
        if (search && b.name.toLowerCase().indexOf(search) === -1 && b.phone.indexOf(search) === -1) return false;
        return true;
      });
    }

    function renderLeadsTable() {
      var wrap = document.getElementById('leads-table-wrap');
      var filtered = getFilteredBookings();
      var countEl = document.getElementById('leads-count');
      if (countEl) countEl.textContent = filtered.length + ' lead' + (filtered.length !== 1 ? 's' : '');

      if (filtered.length === 0) {
        wrap.innerHTML = '<div class="admin-leads-empty">No leads found.</div>';
        return;
      }

      var html = '<table class="admin-leads-table"><thead><tr>' +
        '<th>Date</th><th>Name</th><th>Phone</th><th>Service</th><th>Tier</th><th>Price</th><th>Source</th><th>Status</th>' +
      '</tr></thead><tbody>';

      filtered.forEach(function (b) {
        var dateStr = new Date(b.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
        html += '<tr class="admin-leads-row" data-lead-id="' + escAttr(b.id) + '">' +
          '<td>' + esc(dateStr) + '</td>' +
          '<td><strong>' + esc(b.name || '—') + '</strong></td>' +
          '<td>' + esc(formatPhone(b.phone)) + '</td>' +
          '<td>' + esc(b.service) + '</td>' +
          '<td>' + esc(b.tier) + '</td>' +
          '<td>' + esc(b.price) + '</td>' +
          '<td>' + esc(b.source) + '</td>' +
          '<td><span class="status-badge" data-status="' + escAttr(b.status) + '">' + esc(b.status) + '</span></td>' +
        '</tr>';
        html += '<tr class="admin-leads-detail" data-detail-for="' + escAttr(b.id) + '">' +
          '<td colspan="8">' +
            '<div class="admin-leads-detail-inner">' +
              '<div class="detail-section">' +
                '<h4>Contact Info</h4>' +
                '<p style="font-size:14px;margin-bottom:4px;"><strong>Phone:</strong> ' + esc(formatPhone(b.phone)) + '</p>' +
                (b.email ? '<p style="font-size:14px;margin-bottom:4px;"><strong>Email:</strong> ' + esc(b.email) + '</p>' : '') +
                (b.zip ? '<p style="font-size:14px;margin-bottom:4px;"><strong>ZIP:</strong> ' + esc(b.zip) + '</p>' : '') +
                '<p style="font-size:14px;margin-bottom:4px;"><strong>Service ID:</strong> <code>' + esc(b.serviceId) + '</code></p>' +
                '<p style="font-size:13px;color:#94a3b8;margin-top:8px;">Submitted ' + esc(new Date(b.timestamp).toLocaleString()) + '</p>' +
              '</div>' +
              '<div class="detail-section">' +
                '<h4>Status &amp; Notes</h4>' +
                '<div style="margin-bottom:8px;">' +
                  '<label style="font-size:12px;font-weight:600;color:#64748b;">Status<br/>' +
                  '<select class="admin-status-select" data-status-for="' + escAttr(b.id) + '">' +
                    statusOption('new', b.status) +
                    statusOption('contacted', b.status) +
                    statusOption('scheduled', b.status) +
                    statusOption('completed', b.status) +
                    statusOption('cancelled', b.status) +
                  '</select></label>' +
                '</div>' +
                '<div>' +
                  '<label style="font-size:12px;font-weight:600;color:#64748b;">Internal Notes' +
                  '<textarea class="admin-notes-textarea" data-notes-for="' + escAttr(b.id) + '">' + esc(b.notes || '') + '</textarea></label>' +
                  '<button class="admin-notes-save" data-save-lead="' + escAttr(b.id) + '" type="button">Save</button>' +
                '</div>' +
              '</div>' +
            '</div>' +
          '</td>' +
        '</tr>';
      });

      html += '</tbody></table>';
      wrap.innerHTML = html;
      wireLeadEvents();
    }

    function statusOption(val, current) {
      return '<option value="' + val + '"' + (val === current ? ' selected' : '') + '>' + val.charAt(0).toUpperCase() + val.slice(1) + '</option>';
    }

    function formatPhone(p) {
      if (!p || p.length < 10) return p || '';
      var d = p.replace(/\D/g, '');
      if (d.length === 10) return '(' + d.slice(0,3) + ') ' + d.slice(3,6) + '-' + d.slice(6);
      if (d.length === 11 && d[0] === '1') return '(' + d.slice(1,4) + ') ' + d.slice(4,7) + '-' + d.slice(7);
      return p;
    }

    function wireLeadEvents() {
      // Row expand/collapse
      document.querySelectorAll('.admin-leads-row').forEach(function (row) {
        row.addEventListener('click', function () {
          var id = row.dataset.leadId;
          var detail = document.querySelector('[data-detail-for="' + id + '"]');
          var isVisible = detail.dataset.visible === 'true';
          // Close all others
          document.querySelectorAll('.admin-leads-detail').forEach(function (d) { d.dataset.visible = 'false'; });
          document.querySelectorAll('.admin-leads-row').forEach(function (r) { r.dataset.expanded = 'false'; });
          if (!isVisible) {
            detail.dataset.visible = 'true';
            row.dataset.expanded = 'true';
          }
        });
      });

      // Status change
      document.querySelectorAll('.admin-status-select').forEach(function (sel) {
        sel.addEventListener('change', function () {
          var id = sel.dataset.statusFor;
          updateLead(id, { status: sel.value });
          // Update badge in row
          var row = document.querySelector('[data-lead-id="' + id + '"]');
          if (row) {
            var badge = row.querySelector('.status-badge');
            badge.dataset.status = sel.value;
            badge.textContent = sel.value;
          }
          // Update local data
          var booking = allBookings.find(function (b) { return b.id === id; });
          if (booking) booking.status = sel.value;
        });
      });

      // Save notes
      document.querySelectorAll('[data-save-lead]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.dataset.saveLead;
          var textarea = document.querySelector('[data-notes-for="' + id + '"]');
          var statusSel = document.querySelector('[data-status-for="' + id + '"]');
          var updates = { notes: textarea.value };
          if (statusSel) updates.status = statusSel.value;
          updateLead(id, updates);
          btn.textContent = 'Saved!';
          setTimeout(function () { btn.textContent = 'Save'; }, 1500);
          // Update local
          var booking = allBookings.find(function (b) { return b.id === id; });
          if (booking) {
            booking.notes = textarea.value;
            if (statusSel) booking.status = statusSel.value;
          }
        });
      });
    }

    function updateLead(id, updates) {
      fetch('/api/bookings', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.assign({ id: id }, updates))
      }).catch(function (err) { console.error('Failed to update lead:', err); });
    }

    // ── Export CSV ────────────────────────────────────────────────
    function exportCSV() {
      var filtered = getFilteredBookings();
      if (filtered.length === 0) return;
      var headers = ['Date','Name','Phone','ZIP','Email','Service','Service ID','Tier','Price','Source','Status','Notes'];
      var rows = filtered.map(function (b) {
        return [
          b.timestamp, b.name, b.phone, b.zip, b.email,
          b.service, b.serviceId, b.tier, b.price, b.source, b.status, b.notes
        ].map(function (v) { return '"' + String(v || '').replace(/"/g, '""') + '"'; }).join(',');
      });
      var csv = headers.join(',') + '\n' + rows.join('\n');
      var blob = new Blob([csv], { type: 'text/csv' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'derby-leads-' + new Date().toISOString().slice(0,10) + '.csv';
      a.click();
      URL.revokeObjectURL(url);
    }

    // ── Analytics ────────────────────────────────────────────────
    function renderAnalytics() {
      var el = document.getElementById('analytics-content');
      if (!el) return;

      // Always render header so refresh button works
      var html = renderAnalyticsHeader();

      if (allBookings.length === 0 && allEvents.length === 0) {
        html += '<div class="analytics-empty">' +
          '<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">' +
            '<path d="M3 3v18h18"/>' +
            '<path d="M7 14l4-4 4 4 5-5"/>' +
          '</svg>' +
          '<h3>No data yet</h3>' +
          '<p>As soon as a visitor opens the widget or submits a quote, sessions, conversion funnels, and chat transcripts will show up here.</p>' +
        '</div>';
        el.innerHTML = html;
        wireAnalyticsControls();
        return;
      }

      // Pre-compute everything
      var now = new Date();
      var weekAgo = new Date(now.getTime() - 7 * 86400000);
      var thisWeek = allBookings.filter(function (b) { return new Date(b.timestamp) >= weekAgo; });

      var sessions = {};
      allEvents.forEach(function (e) {
        if (!e.sessionId) return;
        if (!sessions[e.sessionId]) sessions[e.sessionId] = [];
        sessions[e.sessionId].push(e);
      });
      var sessionIds = Object.keys(sessions);

      var funnel = { opened: 0, service: 0, questions: 0, tiers: 0, booking: 0 };
      sessionIds.forEach(function (sid) {
        var evs = sessions[sid];
        var hit = { opened: false, service: false, questions: false, tiers: false, booking: false };
        evs.forEach(function (e) {
          if (e.type === 'widget_opened') hit.opened = true;
          if (e.screen === 'service' || e.type === 'quote_path_selected') hit.service = true;
          if (e.screen === 'questions' || e.type === 'service_selected') hit.questions = true;
          if (e.screen === 'tiers' || e.type === 'tier_viewed') hit.tiers = true;
          if (e.type === 'booking_submitted' || e.type === 'tier_booked') hit.booking = true;
        });
        if (hit.opened) funnel.opened++;
        if (hit.service) funnel.service++;
        if (hit.questions) funnel.questions++;
        if (hit.tiers) funnel.tiers++;
        if (hit.booking) funnel.booking++;
      });

      var chatSessions = sessionIds.filter(function (sid) {
        return sessions[sid].some(function (e) { return e.type === 'chat_message_sent'; });
      });
      var photoSessions = sessionIds.filter(function (sid) {
        return sessions[sid].some(function (e) { return (e.photoCount || 0) > 0; });
      });

      var conversionRate = funnel.opened > 0
        ? Math.round((funnel.booking / funnel.opened) * 1000) / 10
        : 0;

      // ── KPI cards ───────────────────────────────────────────────
      html += '<div class="analytics-kpi-grid">';
      html += kpiCard('Total Leads', allBookings.length, thisWeek.length + ' this week', 'primary');
      html += kpiCard('Sessions', sessionIds.length, funnel.opened + ' widget opens', 'blue');
      html += kpiCard('Conversion Rate', conversionRate + '%', 'opens → booking', 'green');
      html += kpiCard('Chat Conversations', chatSessions.length, photoSessions.length + ' with photos', 'amber');
      html += '</div>';

      // ── Funnel + breakdowns row ─────────────────────────────────
      html += '<div class="analytics-row">';
      html += '<div class="analytics-section"><h3>Conversion Funnel <span class="count-pill">' + sessionIds.length + ' sessions</span></h3>';
      html += renderFunnel([
        { label: 'Opened the widget',  value: funnel.opened },
        { label: 'Picked a service',   value: funnel.service },
        { label: 'Answered questions', value: funnel.questions },
        { label: 'Viewed pricing',     value: funnel.tiers },
        { label: 'Submitted booking',  value: funnel.booking },
      ]);
      html += '</div>';

      // Service breakdown (from leads)
      var byService = {};
      allBookings.forEach(function (b) { if (b.service) byService[b.service] = (byService[b.service] || 0) + 1; });
      html += '<div class="analytics-section"><h3>Leads by Service <span class="count-pill">' + allBookings.length + '</span></h3>';
      html += Object.keys(byService).length
        ? renderBarChart(byService, ['blue', 'green', 'amber', 'purple', 'teal', 'red'])
        : '<p style="color:#94a3b8;font-size:13px;">No bookings yet.</p>';
      html += '</div>';
      html += '</div>';

      // Drop-off screens + tier breakdown
      var dropOffs = {};
      allEvents.forEach(function (e) {
        if (e.type === 'drop_off' && e.lastScreen) dropOffs[e.lastScreen] = (dropOffs[e.lastScreen] || 0) + 1;
      });
      var byTier = {};
      allBookings.forEach(function (b) { if (b.tier) byTier[b.tier] = (byTier[b.tier] || 0) + 1; });

      html += '<div class="analytics-row">';
      html += '<div class="analytics-section"><h3>Drop-off Screens</h3>';
      html += Object.keys(dropOffs).length
        ? renderBarChart(dropOffs, ['red', 'amber', 'purple', 'blue'])
        : '<p style="color:#94a3b8;font-size:13px;">No drop-offs recorded yet.</p>';
      html += '</div>';
      html += '<div class="analytics-section"><h3>Leads by Tier</h3>';
      html += Object.keys(byTier).length
        ? renderBarChart(byTier, ['green', 'amber', 'purple'])
        : '<p style="color:#94a3b8;font-size:13px;">No tier selections yet.</p>';
      html += '</div>';
      html += '</div>';

      // ── Recent sessions ─────────────────────────────────────────
      var recent = sessionIds.map(function (sid) {
        var evs = sessions[sid];
        evs.sort(function (a, b) { return new Date(a.timestamp).getTime() - new Date(b.timestamp).getTime(); });
        return {
          id: sid,
          start: evs[0].timestamp,
          end: evs[evs.length - 1].timestamp,
          eventCount: evs.length,
          chatCount: evs.filter(function (e) { return e.type === 'chat_message_sent'; }).length,
          photoCount: evs.reduce(function (sum, e) { return sum + (e.photoCount || 0); }, 0),
          booked: evs.some(function (e) { return e.type === 'booking_submitted' || e.type === 'tier_booked'; }),
          lastScreen: evs[evs.length - 1].screen || '—',
        };
      }).sort(function (a, b) { return new Date(b.start).getTime() - new Date(a.start).getTime(); }).slice(0, 25);

      html += '<div class="analytics-section"><h3>Recent Sessions <span class="count-pill">click to drill down</span></h3>';
      if (recent.length === 0) {
        html += '<p style="color:#94a3b8;font-size:13px;">No sessions recorded yet.</p>';
      } else {
        html += '<table class="analytics-sessions-table"><thead><tr>' +
          '<th>Started</th><th>Last Screen</th><th>Events</th><th>Chat</th><th>Photos</th><th>Outcome</th><th></th>' +
        '</tr></thead><tbody>';
        recent.forEach(function (s) {
          html += '<tr>' +
            '<td>' + esc(formatRelative(s.start)) + '</td>' +
            '<td><code style="font-size:11px;background:#f1f5f9;padding:2px 6px;border-radius:4px;">' + esc(s.lastScreen) + '</code></td>' +
            '<td>' + s.eventCount + '</td>' +
            '<td>' + (s.chatCount || '<span style="color:#cbd5e1;">—</span>') + '</td>' +
            '<td>' + (s.photoCount || '<span style="color:#cbd5e1;">—</span>') + '</td>' +
            '<td>' + (s.booked
              ? '<span class="analytics-badge" data-tone="green">Booked</span>'
              : '<span class="analytics-badge" data-tone="gray">No booking</span>') + '</td>' +
            '<td><button class="admin-link-btn" data-session-id="' + esc(s.id) + '">View &rarr;</button></td>' +
          '</tr>';
        });
        html += '</tbody></table>';
      }
      html += '</div>';

      html += '<div id="session-drilldown" class="analytics-section" style="display:none;"></div>';

      el.innerHTML = html;
      wireSessionDrilldown();
      wireAnalyticsControls();
    }

    function renderAnalyticsHeader() {
      return '<div class="analytics-page-header">' +
        '<div>' +
          '<h2>Analytics</h2>' +
          '<p>Sessions, conversion funnel, drop-offs, and chat transcripts for the quote widget.</p>' +
        '</div>' +
        '<div class="analytics-page-header-actions">' +
          '<button class="analytics-refresh-btn" id="analytics-refresh-btn" type="button">' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>' +
            'Refresh' +
          '</button>' +
        '</div>' +
      '</div>';
    }

    function wireAnalyticsControls() {
      var btn = document.getElementById('analytics-refresh-btn');
      if (btn) btn.addEventListener('click', function () { loadLeads(); });
    }

    function kpiCard(label, value, sub, tone) {
      return '<div class="analytics-kpi" data-tone="' + esc(tone || 'primary') + '">' +
        '<div class="analytics-kpi-label">' + esc(label) + '</div>' +
        '<div class="analytics-kpi-value">' + esc(String(value)) + '</div>' +
        (sub ? '<div class="analytics-kpi-sub">' + esc(sub) + '</div>' : '') +
      '</div>';
    }

    function renderFunnel(steps) {
      if (steps.length === 0) return '';
      var max = steps[0].value || 1;
      var html = '';
      steps.forEach(function (s, i) {
        var pct = max > 0 ? Math.max(2, Math.round((s.value / max) * 100)) : 2;
        var rate = (i > 0 && steps[i - 1].value > 0)
          ? Math.round((s.value / steps[i - 1].value) * 100) + '% from prev'
          : '';
        html += '<div class="analytics-funnel-step">' +
          '<div class="analytics-funnel-num">' + (i + 1) + '</div>' +
          '<div>' +
            '<div style="font-size:13px;font-weight:600;color:#0E121B;margin-bottom:4px;">' + esc(s.label) +
              (rate ? ' <span class="analytics-funnel-rate">&middot; ' + rate + '</span>' : '') +
            '</div>' +
            '<div class="analytics-funnel-bar">' +
              '<div class="analytics-funnel-fill" style="width:' + pct + '%">' +
                (s.value > 0 ? s.value : '') +
              '</div>' +
            '</div>' +
          '</div>' +
          '<div class="analytics-funnel-count">' + s.value + '</div>' +
        '</div>';
      });
      return html;
    }

    function formatRelative(iso) {
      var d = new Date(iso);
      var diff = (Date.now() - d.getTime()) / 1000;
      if (diff < 60) return Math.floor(diff) + 's ago';
      if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      if (diff < 7 * 86400) return Math.floor(diff / 86400) + 'd ago';
      return d.toLocaleDateString();
    }

    function wireSessionDrilldown() {
      var btns = document.querySelectorAll('[data-session-id]');
      btns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          renderSessionDrilldown(btn.getAttribute('data-session-id'));
        });
      });
    }

    function renderSessionDrilldown(sessionId) {
      var panel = document.getElementById('session-drilldown');
      if (!panel) return;
      var evs = allEvents.filter(function (e) { return e.sessionId === sessionId; });
      evs.sort(function (a, b) { return new Date(a.timestamp).getTime() - new Date(b.timestamp).getTime(); });
      if (evs.length === 0) {
        panel.style.display = 'none';
        return;
      }
      var duration = Math.round((new Date(evs[evs.length - 1].timestamp).getTime() - new Date(evs[0].timestamp).getTime()) / 1000);

      var html = '<h3>Session timeline <span class="count-pill">' + evs.length + ' events &middot; ' + duration + 's</span></h3>';
      html += '<div style="font-size:12px;color:#94a3b8;margin-bottom:16px;font-family:ui-monospace,monospace;">' + esc(sessionId) + '</div>';

      evs.forEach(function (e) {
        var detail = '';
        if (e.role && e.message) {
          detail = '<div class="session-chat-bubble" data-role="' + esc(e.role) + '">' +
            '<strong>' + esc(e.role) + ':</strong> ' + esc(e.message) +
          '</div>';
        } else if (e.serviceId) detail = 'service: <strong>' + esc(e.serviceId) + '</strong>';
        else if (e.tier) detail = 'tier: <strong>' + esc(e.tier) + '</strong>';
        else if (e.lastScreen) detail = 'last screen: <strong>' + esc(e.lastScreen) + '</strong>';
        else if (e.route) detail = 'route: <strong>' + esc(e.route) + '</strong>';
        else if (e.photoCount) detail = '<strong>' + e.photoCount + '</strong> photo(s) attached';
        else if (e.screen) detail = '<span style="color:#94a3b8;">screen: ' + esc(e.screen) + '</span>';

        html += '<div class="session-event-row">' +
          '<div class="session-event-time">' + esc(new Date(e.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' })) + '</div>' +
          '<div><span class="session-event-type">' + esc(e.type) + '</span></div>' +
          '<div class="session-event-detail">' + detail + '</div>' +
        '</div>';
      });

      panel.innerHTML = html;
      panel.style.display = 'block';
      panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function analyticsCard(value, label) {
      return '<div class="analytics-card"><div class="metric">' + value + '</div><div class="metric-label">' + esc(label) + '</div></div>';
    }

    function renderBarChart(data, colors) {
      var entries = Object.entries(data).sort(function (a, b) { return b[1] - a[1]; });
      if (entries.length === 0) return '<p style="color:#94a3b8;font-size:13px;">No data</p>';
      var max = entries[0][1];
      var html = '';
      entries.forEach(function (entry, i) {
        var pct = max > 0 ? Math.round((entry[1] / max) * 100) : 0;
        var color = colors[i % colors.length];
        html += '<div class="analytics-bar-row">' +
          '<span class="analytics-bar-label">' + esc(entry[0]) + '</span>' +
          '<div class="analytics-bar-track"><div class="analytics-bar-fill" data-color="' + color + '" style="width:' + pct + '%"></div></div>' +
          '<span class="analytics-bar-count">' + entry[1] + '</span>' +
        '</div>';
      });
      return html;
    }

    // ── Keyboard shortcut: Ctrl+S to save ────────────────────────
    document.addEventListener('keydown', function (e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        saveConfig();
      }
    });

    // ── Storage status check ────────────────────────────────────
    function checkStorageStatus() {
      fetch('/api/storage-status')
        .then(function (r) { return r.json(); })
        .then(function (d) {
          var banner = document.getElementById('admin-storage-banner');
          if (!banner) return;
          if (d.kvEnabled) {
            banner.style.display = 'none';
          } else {
            document.getElementById('admin-storage-banner-text').textContent =
              d.warning || 'Vercel KV is not attached. Data will not persist.';
            banner.style.display = 'block';
          }
        })
        .catch(function () { /* non-critical */ });
    }

    // ── Init ─────────────────────────────────────────────────────
    checkStorageStatus();
    loadConfig();
    // Chat config is wired after renderEditor via wireEvents
  })();
  </script>
</body>
</html>
